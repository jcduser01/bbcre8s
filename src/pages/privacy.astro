---
/*
  /privacy — INI-059 Treatment B privacy page (staged).
  Ported near-verbatim from the client-approved mockup
  (workspaces/creative/INI-059/treatment-b-mockups/privacy.html) so the staged
  /v2 one-pager's footer "Privacy Policy" link resolves. Self-contained
  (own inline styles) to avoid coupling the shared nb components to the staging
  path. Cross-page links point at the staged home (/); Session 2's root
  cutover flips those to "/". Copy is placeholder pending client/legal review.
*/
const lastUpdated = "June 2026";
---
<html lang="en">
<head>
<meta charset="UTF-8" />
<meta name="viewport" content="width=device-width, initial-scale=1.0" />
<meta name="theme-color" content="#FFFFFF" />
<meta name="robots" content="noindex, nofollow" />
<title>Privacy Policy · bbcre8s</title>
<link rel="preconnect" href="https://fonts.googleapis.com" />
<link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
<link href="https://fonts.googleapis.com/css2?family=Space+Grotesk:wght@400;500;600;700&family=Manrope:wght@400;500;600;700&display=swap" rel="stylesheet" />
<style is:global>
:root{
  --bg:#FFFFFF;--bg-strong:#F2F2F2;--accent:#D9A5B3;--accent-strong:#C48F9C;--accent-blush:#F5E5EA;
  --accent-blue:#A8C6DF;--accent-blue-tint:#D6E8F2;--nb-charcoal:#333333;--ink:#333333;--ink-soft:#555555;--ink-faint:#888888;--ink-on-dark:#FFFFFF;
  --font-display:"Space Grotesk","Archivo Black","Helvetica Neue",sans-serif;--font-body:"Manrope","Helvetica Neue","Segoe UI",sans-serif;
  --text-display:clamp(3.5rem,8vw,6rem);--text-h1:clamp(2.25rem,5vw,3.5rem);--text-h2:clamp(1.75rem,3vw,2.25rem);--text-h3:1.5rem;--text-h4:1.125rem;--text-body:1rem;--text-small:0.875rem;--text-micro:0.75rem;
  --space-1:0.5rem;--space-2:0.75rem;--space-3:1rem;--space-4:1.5rem;--space-5:2rem;--space-6:3rem;--space-7:4rem;--space-8:5.5rem;--radius-sm:4px;
  --shadow-hard:6px 6px 0 var(--nb-charcoal);--shadow-hard-sm:4px 4px 0 var(--nb-charcoal);--shadow-hard-rose:6px 6px 0 var(--accent);--shadow-hard-lg:8px 8px 0 var(--nb-charcoal);
  --border-neo:2.5px solid var(--nb-charcoal);--border-neo-thick:3.5px solid var(--nb-charcoal);--border-neo-accent:2.5px solid var(--accent);
  --content-max:72rem;--content-narrow:48rem;--header-height:4.75rem;--transition:150ms ease;
}
*,*::before,*::after{box-sizing:border-box;margin:0;padding:0;}
html{scroll-behavior:smooth;}
body{font-family:var(--font-body);font-size:var(--text-body);color:var(--ink);background:var(--bg);line-height:1.7;-webkit-font-smoothing:antialiased;min-height:100vh;display:flex;flex-direction:column;}
a{color:inherit;text-decoration:none;}
.container{width:100%;max-width:var(--content-max);margin:0 auto;padding:0 var(--space-5);}
.btn{display:inline-flex;align-items:center;gap:var(--space-2);font-family:var(--font-body);font-size:var(--text-small);font-weight:700;letter-spacing:0.06em;text-transform:uppercase;padding:0.9rem 1.85rem;border-radius:var(--radius-sm);cursor:pointer;transition:transform var(--transition),box-shadow var(--transition),background var(--transition);border:none;}
.btn-primary{background:var(--accent);color:var(--nb-charcoal);border:var(--border-neo);box-shadow:var(--shadow-hard-sm);}
.btn-primary:hover{transform:translate(4px,4px);box-shadow:1px 1px 0 var(--nb-charcoal);}
.btn-outline{background:var(--bg);color:var(--nb-charcoal);border:var(--border-neo);box-shadow:var(--shadow-hard-sm);}
.btn-outline:hover{transform:translate(4px,4px);box-shadow:1px 1px 0 var(--nb-charcoal);}
@media (prefers-reduced-motion:reduce){.btn:hover{transform:none;box-shadow:var(--shadow-hard-sm);}}
.site-nav{height:var(--header-height);display:flex;align-items:center;background:#fff;border-bottom:var(--border-neo-thick);position:sticky;top:0;z-index:50;}
.site-nav .container{display:flex;align-items:center;justify-content:space-between;}
.nav-logo{font-family:var(--font-display);font-size:1.4rem;font-weight:700;color:var(--ink);letter-spacing:-0.02em;}
.nav-logo span{color:var(--accent-strong);}
.nav-links{display:flex;gap:var(--space-4);list-style:none;}
.nav-links a{font-family:var(--font-body);font-size:var(--text-small);font-weight:600;color:var(--ink-soft);}
.nav-links a:hover{color:var(--ink);}
@media (max-width:680px){.nav-links{display:none;}}
.doc-head{background:var(--accent-blush);border-bottom:var(--border-neo-thick);padding:var(--space-7) 0;}
.doc-eyebrow{display:inline-flex;padding:0.3rem 0.75rem;border:var(--border-neo-accent);box-shadow:3px 3px 0 var(--accent);font-size:var(--text-micro);font-weight:700;letter-spacing:0.12em;text-transform:uppercase;color:var(--nb-charcoal);background:var(--bg);margin-bottom:var(--space-3);}
.doc-title{font-family:var(--font-display);font-size:var(--text-h1);font-weight:700;letter-spacing:-0.02em;color:var(--nb-charcoal);}
.doc-updated{font-family:var(--font-body);font-size:var(--text-small);color:var(--ink-soft);margin-top:var(--space-2);}
.doc-wrap{flex:1;padding:var(--space-7) 0;}
.doc-body{max-width:var(--content-narrow);}
.doc-body h2{font-family:var(--font-display);font-size:var(--text-h3);font-weight:700;color:var(--nb-charcoal);margin:var(--space-6) 0 var(--space-2);padding-top:var(--space-3);border-top:2.5px solid var(--nb-charcoal);}
.doc-body h2:first-of-type{border-top:none;padding-top:0;margin-top:0;}
.doc-body p{margin-bottom:var(--space-3);color:var(--ink-soft);}
.doc-body ul{margin:0 0 var(--space-3) var(--space-5);color:var(--ink-soft);}
.doc-body li{margin-bottom:var(--space-1);}
.doc-body a{color:var(--nb-charcoal);font-weight:700;text-decoration:underline;text-underline-offset:0.2em;}
.site-footer{background:var(--nb-charcoal);padding:var(--space-7) 0 var(--space-5);border-top:3.5px solid var(--accent);color:var(--ink-on-dark);}
.footer-top{display:grid;grid-template-columns:1.6fr 1fr 1fr;gap:var(--space-6);padding-bottom:var(--space-5);}
.footer-brand-col{max-width:22rem;}
.footer-logo{font-family:var(--font-display);font-size:1.6rem;font-weight:700;color:var(--ink-on-dark);letter-spacing:-0.02em;}
.footer-logo span{color:var(--accent);}
.footer-tag{font-family:var(--font-body);font-size:var(--text-small);color:rgba(255,255,255,0.62);margin:var(--space-2) 0 var(--space-3);line-height:1.55;}
.footer-email{display:inline-block;font-family:var(--font-display);font-weight:700;font-size:var(--text-h4);color:var(--ink-on-dark);border-bottom:2.5px solid var(--accent);padding-bottom:0.15rem;}
.footer-email:hover{color:var(--accent);}
.footer-col-title{font-family:var(--font-body);font-size:var(--text-micro);font-weight:700;letter-spacing:0.14em;text-transform:uppercase;color:var(--accent);margin-bottom:var(--space-3);}
.footer-nav{list-style:none;display:flex;flex-direction:column;gap:var(--space-2);}
.footer-nav a{font-family:var(--font-body);font-size:var(--text-small);font-weight:500;color:rgba(255,255,255,0.78);transition:color var(--transition);}
.footer-nav a:hover{color:var(--accent);}
.footer-social{display:flex;flex-direction:column;align-items:flex-start;gap:var(--space-2);}
.social-chip{display:inline-flex;align-items:center;padding:0.4rem 0.85rem;border:2.5px solid rgba(255,255,255,0.55);box-shadow:4px 4px 0 rgba(255,255,255,0.18);font-family:var(--font-body);font-size:var(--text-micro);font-weight:700;letter-spacing:0.08em;text-transform:uppercase;color:var(--ink-on-dark);background:transparent;transition:transform var(--transition),box-shadow var(--transition),background var(--transition);}
.social-chip:hover{background:var(--accent);color:var(--nb-charcoal);border-color:var(--accent);transform:translate(4px,4px);box-shadow:1px 1px 0 var(--accent);}
.footer-bottom{border-top:2.5px solid rgba(255,255,255,0.18);padding-top:var(--space-4);display:flex;flex-wrap:wrap;align-items:center;justify-content:space-between;gap:var(--space-3);}
.footer-copy{font-family:var(--font-body);font-size:var(--text-micro);color:rgba(255,255,255,0.45);}
.footer-legal{display:flex;flex-wrap:wrap;gap:var(--space-4);}
.footer-legal a{font-family:var(--font-body);font-size:var(--text-micro);font-weight:600;color:rgba(255,255,255,0.70);}
.footer-legal a:hover{color:var(--accent);}
.footer-legal button.link-reset{background:none;border:none;cursor:pointer;font-family:var(--font-body);font-size:var(--text-micro);font-weight:600;color:rgba(255,255,255,0.70);padding:0;}
.footer-legal button.link-reset:hover{color:var(--accent);}
@media (max-width:760px){.footer-top{grid-template-columns:1fr 1fr;}.footer-brand-col{grid-column:1/-1;max-width:none;}}
@media (max-width:480px){.footer-top{grid-template-columns:1fr;}.footer-bottom{flex-direction:column;align-items:flex-start;}}
.cookie-banner{position:fixed;left:var(--space-4);right:var(--space-4);bottom:var(--space-4);z-index:800;max-width:40rem;margin-left:auto;background:var(--bg);border:var(--border-neo-thick);box-shadow:var(--shadow-hard-lg);padding:var(--space-4) var(--space-5);}
.cookie-banner[hidden]{display:none;}
.cookie-title{font-family:var(--font-display);font-size:var(--text-h4);font-weight:700;color:var(--nb-charcoal);margin-bottom:var(--space-1);}
.cookie-text{font-family:var(--font-body);font-size:var(--text-small);color:var(--ink-soft);line-height:1.55;margin-bottom:var(--space-3);}
.cookie-text a{font-weight:700;color:var(--nb-charcoal);text-decoration:underline;text-underline-offset:0.2em;}
.cookie-actions{display:flex;flex-wrap:wrap;gap:var(--space-2);}
.cookie-actions .btn{padding:0.7rem 1.4rem;font-size:var(--text-micro);}
@media (max-width:480px){.cookie-actions .btn{flex:1;justify-content:center;}}
:focus-visible{outline:3px solid var(--accent-blue);outline-offset:3px;}
</style>
</head>
<body>

<nav class="site-nav" aria-label="Site navigation">
  <div class="container">
    <a href="/" class="nav-logo">bb<span>cre8s</span></a>
    <ul class="nav-links">
      <li><a href="/#portfolio">Portfolio</a></li>
      <li><a href="/#services">Services</a></li>
      <li><a href="/#contact">Contact</a></li>
    </ul>
    <a href="/" class="btn btn-primary">Back to Site</a>
  </div>
</nav>

<header class="doc-head">
  <div class="container">
    <span class="doc-eyebrow">Legal</span>
    <h1 class="doc-title">Privacy Policy</h1>
    <p class="doc-updated">Last updated: {lastUpdated} · bbcre8s.com</p>
  </div>
</header>

<main class="doc-wrap">
  <div class="container">
    <div class="doc-body">

      <h2>Who we are</h2>
      <p>This website (bbcre8s.com) is operated by Bella B Creates ("we," "us"). This policy explains what personal information we collect, why, and what choices you have. Questions: <a href="mailto:info@bbcre8s.com">info@bbcre8s.com</a>.</p>

      <h2>Information we collect</h2>
      <p>We only collect what you choose to give us, plus limited analytics:</p>
      <ul>
        <li><strong>Contact form:</strong> your name, email address, brand/company (optional), and your message. Submitted through our form provider (Web3Forms) and delivered to us by email.</li>
        <li><strong>Booking:</strong> if you schedule a call, the scheduling tool (cal.com) collects your name, email, and chosen time to confirm the appointment.</li>
        <li><strong>Analytics:</strong> with your consent, Google Analytics collects anonymized usage data (pages viewed, approximate region, device type) to help us improve the site.</li>
      </ul>

      <h2>How we use it</h2>
      <p>To reply to your inquiry, schedule and confirm calls, and understand how the site is used so we can improve it. We do not sell your personal information.</p>

      <h2>Cookies &amp; analytics</h2>
      <p>Analytics cookies load <strong>only after you accept</strong> them in our cookie banner. If you decline, Google Analytics is not loaded. You can change your choice any time via "Cookie Settings" in the footer. Essential functionality does not require analytics cookies.</p>

      <h2>Third parties</h2>
      <p>We rely on a small number of trusted services that process data on our behalf: Web3Forms (form delivery), cal.com (scheduling), and Google Analytics (usage measurement). Each has its own privacy practices.</p>

      <h2>Data retention</h2>
      <p>We keep inquiry emails only as long as needed to respond and maintain our working relationship, then delete them. Analytics data is retained per Google Analytics' configured retention window.</p>

      <h2>Your rights</h2>
      <p>You can ask us to access, correct, or delete the personal information you've given us. Email <a href="mailto:info@bbcre8s.com">info@bbcre8s.com</a> and we'll respond within a reasonable time. Depending on where you live, you may have additional rights under laws such as the GDPR or CCPA.</p>

      <h2>Changes to this policy</h2>
      <p>We may update this policy as the site evolves. The "last updated" date above reflects the current version.</p>

    </div>
  </div>
</main>

<footer class="site-footer" aria-label="Site footer">
  <div class="container">
    <div class="footer-top">
      <div class="footer-brand-col">
        <span class="footer-logo">bb<span>cre8s</span></span>
        <p class="footer-tag">Video-first UGC and event content for brands that want to connect, engage, and convert — backed by 10+ years of real event production.</p>
        <a class="footer-email" href="mailto:info@bbcre8s.com">info@bbcre8s.com</a>
      </div>
      <div class="footer-col">
        <p class="footer-col-title">Explore</p>
        <ul class="footer-nav">
          <li><a href="/#portfolio">Portfolio</a></li>
          <li><a href="/#services">Services</a></li>
          <li><a href="/#process">Process</a></li>
          <li><a href="/#contact">Work With Me</a></li>
          <li><a href="/links">Links</a></li>
        </ul>
      </div>
      <div class="footer-col">
        <p class="footer-col-title">Follow</p>
        <div class="footer-social">
          <a class="social-chip" href="#" aria-label="Instagram (placeholder)">Instagram</a>
          <a class="social-chip" href="#" aria-label="TikTok (placeholder)">TikTok</a>
          <a class="social-chip" href="#" aria-label="YouTube (placeholder)">YouTube</a>
        </div>
      </div>
    </div>
    <div class="footer-bottom">
      <p class="footer-copy">&copy; 2026 Bella B Creates. All rights reserved.</p>
      <nav class="footer-legal" aria-label="Legal">
        <a href="/privacy">Privacy Policy</a>
        <button type="button" class="link-reset" data-cookie-open>Cookie Settings</button>
      </nav>
    </div>
  </div>
</footer>

<aside class="cookie-banner" id="cookie-banner" role="region" aria-label="Cookie consent" hidden>
  <p class="cookie-title">Cookies, the honest kind.</p>
  <p class="cookie-text">We use Google Analytics to understand how the site is used. Nothing loads until you say so.</p>
  <div class="cookie-actions">
    <button type="button" class="btn btn-primary" data-cookie-accept>Accept</button>
    <button type="button" class="btn btn-outline" data-cookie-decline>Decline</button>
  </div>
</aside>

<script is:inline>
const cookieBanner=document.getElementById('cookie-banner');
function getConsent(){try{return localStorage.getItem('bb-consent');}catch(e){return null;}}
function setConsent(v){try{localStorage.setItem('bb-consent',v);}catch(e){}}
function initConsent(){const c=getConsent();if(c==='accepted'||c==='declined')return;cookieBanner.hidden=false;}
document.querySelector('[data-cookie-accept]')?.addEventListener('click',()=>{setConsent('accepted');cookieBanner.hidden=true;});
document.querySelector('[data-cookie-decline]')?.addEventListener('click',()=>{setConsent('declined');cookieBanner.hidden=true;});
document.querySelector('[data-cookie-open]')?.addEventListener('click',()=>{cookieBanner.hidden=false;});
initConsent();
</script>
</body>
</html>
