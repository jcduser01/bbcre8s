---
/*
  /links — INI-059 Treatment B Link-in-Bio page (staged). Replaces the legacy
  links page. Ported near-verbatim from the client-approved mockup
  (workspaces/creative/INI-059/treatment-b-mockups/links.html). Self-contained
  by design (purpose-built mobile Link-in-Bio, kept separate from the one-pager).
  Cross-page links point at the staged home (/); Session 2's root cutover
  flips those to "/".
*/
---
<html lang="en">
<head>
<meta charset="UTF-8" />
<meta name="viewport" content="width=device-width, initial-scale=1.0" />
<meta name="theme-color" content="#F5E5EA" />
<meta name="robots" content="noindex, nofollow" />
<title>Links · bbcre8s</title>
<link rel="preconnect" href="https://fonts.googleapis.com" />
<link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
<link href="https://fonts.googleapis.com/css2?family=Space+Grotesk:wght@400;500;600;700&family=Manrope:wght@400;500;600;700&display=swap" rel="stylesheet" />
<style is:global>
:root{
  --bg:#FFFFFF;--accent:#D9A5B3;--accent-strong:#C48F9C;--accent-blush:#F5E5EA;--accent-blue:#A8C6DF;
  --nb-charcoal:#333333;--ink:#333333;--ink-soft:#555555;--ink-faint:#888888;--ink-on-dark:#FFFFFF;
  --font-display:"Space Grotesk","Archivo Black","Helvetica Neue",sans-serif;--font-body:"Manrope","Helvetica Neue","Segoe UI",sans-serif;
  --text-h1:clamp(2.25rem,5vw,3.5rem);--text-h3:1.5rem;--text-h4:1.125rem;--text-body:1rem;--text-small:0.875rem;--text-micro:0.75rem;
  --space-1:0.5rem;--space-2:0.75rem;--space-3:1rem;--space-4:1.5rem;--space-5:2rem;--space-6:3rem;--space-7:4rem;--radius-sm:4px;
  --shadow-hard:6px 6px 0 var(--nb-charcoal);--shadow-hard-sm:4px 4px 0 var(--nb-charcoal);--shadow-hard-rose:6px 6px 0 var(--accent);
  --border-neo:2.5px solid var(--nb-charcoal);--border-neo-thick:3.5px solid var(--nb-charcoal);--transition:150ms ease;
}
*,*::before,*::after{box-sizing:border-box;margin:0;padding:0;}
body{font-family:var(--font-body);color:var(--ink);background:var(--accent-blush);line-height:1.6;-webkit-font-smoothing:antialiased;min-height:100vh;display:flex;flex-direction:column;}
a{color:inherit;text-decoration:none;}
img{display:block;max-width:100%;}
.bio-top{display:flex;align-items:center;justify-content:space-between;padding:var(--space-3) var(--space-4);border-bottom:var(--border-neo-thick);background:#fff;}
.bio-logo{font-family:var(--font-display);font-size:1.25rem;font-weight:700;}
.bio-logo span{color:var(--accent-strong);}
.bio-fullsite{font-family:var(--font-body);font-size:var(--text-micro);font-weight:700;letter-spacing:0.08em;text-transform:uppercase;color:var(--ink-soft);border:var(--border-neo);box-shadow:var(--shadow-hard-sm);padding:0.4rem 0.8rem;background:#fff;transition:transform var(--transition),box-shadow var(--transition);}
.bio-fullsite:hover{transform:translate(3px,3px);box-shadow:1px 1px 0 var(--nb-charcoal);}
.bio-wrap{flex:1;display:flex;justify-content:center;padding:var(--space-6) var(--space-4) var(--space-7);}
.bio-col{width:100%;max-width:30rem;}
.bio-head{text-align:center;margin-bottom:var(--space-6);}
.bio-avatar{width:96px;height:96px;margin:0 auto var(--space-3);border:var(--border-neo-thick);box-shadow:var(--shadow-hard);background:var(--accent);}
.bio-name{font-family:var(--font-display);font-size:var(--text-h1);font-weight:700;letter-spacing:-0.02em;line-height:1;}
.bio-handle{display:inline-block;margin-top:var(--space-2);font-family:var(--font-body);font-size:var(--text-small);font-weight:700;letter-spacing:0.06em;text-transform:uppercase;color:var(--nb-charcoal);border:2.5px solid var(--accent);box-shadow:3px 3px 0 var(--accent);padding:0.2rem 0.7rem;background:#fff;}
.bio-tagline{margin-top:var(--space-3);font-size:var(--text-small);color:var(--ink-soft);}
.bio-links{display:flex;flex-direction:column;gap:var(--space-3);}
.bio-link{display:flex;align-items:center;gap:var(--space-3);padding:1.1rem 1.25rem;background:#fff;border:var(--border-neo);box-shadow:var(--shadow-hard);font-family:var(--font-display);font-weight:700;font-size:var(--text-h4);color:var(--nb-charcoal);transition:transform var(--transition),box-shadow var(--transition),background var(--transition);}
.bio-link:hover{transform:translate(-4px,-4px);box-shadow:10px 10px 0 var(--accent);}
.bio-link .ico{width:1.6rem;text-align:center;flex-shrink:0;font-size:1.2rem;}
.bio-link .arrow{margin-left:auto;color:var(--ink-faint);font-weight:700;}
.bio-link.primary{background:var(--accent);}
.bio-link.primary:hover{box-shadow:10px 10px 0 var(--nb-charcoal);}
@media (prefers-reduced-motion:reduce){.bio-link:hover,.bio-fullsite:hover{transform:none;box-shadow:var(--shadow-hard);}}
.bio-footer{background:var(--nb-charcoal);color:var(--ink-on-dark);border-top:3.5px solid var(--accent);padding:var(--space-4);text-align:center;}
.bio-footer-legal{display:flex;flex-wrap:wrap;gap:var(--space-4);justify-content:center;margin-bottom:var(--space-2);}
.bio-footer-legal a,.bio-footer-legal button{font-family:var(--font-body);font-size:var(--text-micro);font-weight:600;color:rgba(255,255,255,0.72);background:none;border:none;cursor:pointer;padding:0;}
.bio-footer-legal a:hover,.bio-footer-legal button:hover{color:var(--accent);}
.bio-copy{font-family:var(--font-body);font-size:var(--text-micro);color:rgba(255,255,255,0.4);}
.cookie-banner{position:fixed;left:var(--space-3);right:var(--space-3);bottom:var(--space-3);z-index:800;max-width:34rem;margin:0 auto;background:var(--bg);border:var(--border-neo-thick);box-shadow:6px 6px 0 var(--nb-charcoal);padding:var(--space-4);}
.cookie-banner[hidden]{display:none;}
.cookie-title{font-family:var(--font-display);font-size:var(--text-h4);font-weight:700;margin-bottom:var(--space-1);}
.cookie-text{font-family:var(--font-body);font-size:var(--text-small);color:var(--ink-soft);margin-bottom:var(--space-3);}
.cookie-text a{font-weight:700;color:var(--nb-charcoal);text-decoration:underline;}
.cookie-actions{display:flex;gap:var(--space-2);}
.cookie-actions button{flex:1;font-family:var(--font-body);font-weight:700;font-size:var(--text-micro);letter-spacing:0.06em;text-transform:uppercase;padding:0.7rem 1rem;border-radius:var(--radius-sm);cursor:pointer;}
.cb-accept{background:var(--accent);color:var(--nb-charcoal);border:var(--border-neo);box-shadow:var(--shadow-hard-sm);}
.cb-decline{background:#fff;color:var(--nb-charcoal);border:var(--border-neo);box-shadow:var(--shadow-hard-sm);}
:focus-visible{outline:3px solid var(--accent-blue);outline-offset:3px;}
</style>
</head>
<body>

<div class="bio-top">
  <span class="bio-logo">bb<span>cre8s</span></span>
  <a class="bio-fullsite" href="/">Full Site</a>
</div>

<main class="bio-wrap">
  <div class="bio-col">

    <div class="bio-head">
      <img class="bio-avatar" src="https://placehold.co/192x192/D9A5B3/333333?text=BB" alt="Bella B Creates" />
      <h1 class="bio-name">Bella B Creates</h1>
      <span class="bio-handle">@bbcre8s</span>
      <p class="bio-tagline">UGC · Travel · Events · Lifestyle — content that helps brands connect, engage, and convert.</p>
    </div>

    <nav class="bio-links" aria-label="Links">
      <a class="bio-link primary" href="/#contact"><span class="ico" aria-hidden="true">📅</span> Book a Call <span class="arrow" aria-hidden="true">→</span></a>
      <a class="bio-link" href="/#portfolio"><span class="ico" aria-hidden="true">🎬</span> Watch the Reels <span class="arrow" aria-hidden="true">→</span></a>
      <a class="bio-link" href="/#services"><span class="ico" aria-hidden="true">📦</span> Services &amp; Rates <span class="arrow" aria-hidden="true">→</span></a>
      <a class="bio-link" href="mailto:info@bbcre8s.com"><span class="ico" aria-hidden="true">✉️</span> Email Me <span class="arrow" aria-hidden="true">→</span></a>
      <a class="bio-link" href="#" aria-label="Instagram (placeholder)"><span class="ico" aria-hidden="true">📸</span> Instagram <span class="arrow" aria-hidden="true">↗</span></a>
      <a class="bio-link" href="#" aria-label="TikTok (placeholder)"><span class="ico" aria-hidden="true">🎵</span> TikTok <span class="arrow" aria-hidden="true">↗</span></a>
      <a class="bio-link" href="#" aria-label="YouTube (placeholder)"><span class="ico" aria-hidden="true">▶️</span> YouTube <span class="arrow" aria-hidden="true">↗</span></a>
    </nav>

  </div>
</main>

<footer class="bio-footer">
  <div class="bio-footer-legal">
    <a href="/">Home</a>
    <a href="/privacy">Privacy</a>
    <button type="button" data-cookie-open>Cookie Settings</button>
  </div>
  <p class="bio-copy">&copy; 2026 Bella B Creates. All rights reserved.</p>
</footer>

<aside class="cookie-banner" id="cookie-banner" role="region" aria-label="Cookie consent" hidden>
  <p class="cookie-title">Cookies, the honest kind.</p>
  <p class="cookie-text">We use Google Analytics to understand how this page is used. Nothing loads until you say so. <a href="/privacy">Privacy Policy</a>.</p>
  <div class="cookie-actions">
    <button type="button" class="cb-accept" data-cookie-accept>Accept</button>
    <button type="button" class="cb-decline" data-cookie-decline>Decline</button>
  </div>
</aside>

<script is:inline>
const cookieBanner=document.getElementById('cookie-banner');
function getConsent(){try{return localStorage.getItem('bb-consent');}catch(e){return null;}}
function setConsent(v){try{localStorage.setItem('bb-consent',v);}catch(e){}}
function initConsent(){const c=getConsent();if(c==='accepted'||c==='declined')return;cookieBanner.hidden=false;}
document.querySelector('[data-cookie-accept]')?.addEventListener('click',()=>{setConsent('accepted');cookieBanner.hidden=true;});
document.querySelector('[data-cookie-decline]')?.addEventListener('click',()=>{setConsent('declined');cookieBanner.hidden=true;});
document.querySelector('[data-cookie-open]')?.addEventListener('click',()=>{cookieBanner.hidden=false;});
initConsent();
</script>
</body>
</html>
